// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  ANALYST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ANALYST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  analyses Analysis[]
  reports  Report[]

  @@map("users")
}

enum AnalysisStatus {
  SUCCESS
  FAILED
}

model Analysis {
  id        String         @id @default(uuid())
  userId    String
  text      String
  textHash  String
  sentiment String?
  keywords  Json?
  status    AnalysisStatus @default(SUCCESS)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([textHash])
}

enum ReportStatus {
  COMPLETED
}


model Report {
  id                       String   @id @default(cuid())
  requestedBy              String
  dateFrom                 DateTime
  dateTo                   DateTime
  isEmpty                  Boolean
  coversOnlyInactiveUsers  Boolean  @default(false)
  data                     Json
  status                   ReportStatus
  createdAt                DateTime @default(now())

  user User @relation(fields: [requestedBy], references: [id])

  @@index([requestedBy])
}
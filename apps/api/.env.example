# Database
DATABASE_URL="postgresql://userhub:userhub_secret@localhost:5432/userhub"

# Postgres (for docker-compose)
POSTGRES_USER=userhub
POSTGRES_PASSWORD=userhub_secret
POSTGRES_DB=userhub
POSTGRES_PORT=5432

# JWT
JWT_SECRET=change_me_in_production_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
